<%- include('../layouts/header') %>

<div style="margin-bottom: 24px;">
    <a href="/applicant/dashboard" class="btn btn-secondary btn-text" style="padding-left: 0; color: var(--text-secondary);"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
</div>

<div style="display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 28px; align-items: start;">
    <!-- Job Details Section -->
    <div class="card" style="padding: 32px;">
        <div style="display: flex; gap: 20px; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 20px; margin-bottom: 24px;">
            <% 
                const code = job.company_name.charCodeAt(0) % 5 + 1; 
                const initial = job.company_name.charAt(0).toUpperCase();
            %>
            <div class="company-avatar bg-<%= code %>" style="width: 56px; height: 56px; font-size: 1.35rem; border-radius: 12px;">
                <%= initial %>
            </div>
            <div>
                <span class="company-name" style="font-size: 0.95rem; font-weight: 600;"><%= job.company_name %></span>
                <h1 style="font-size: 1.75rem; font-weight: 800; letter-spacing: -0.5px; margin-top: 2px;"><%= job.title %></h1>
            </div>
        </div>

        <div class="job-card-details" style="margin-bottom: 24px; gap: 10px;">
            <span class="tag" style="font-size: 0.8rem; padding: 4px 10px;"><i class="fa-solid fa-location-dot"></i> <%= job.location %></span>
            <span class="tag tag-success" style="font-size: 0.8rem; padding: 4px 10px;"><i class="fa-solid fa-indian-rupee-sign"></i> <%= job.stipend.toLocaleString() %>/mo</span>
            <span class="tag tag-primary" style="font-size: 0.8rem; padding: 4px 10px;"><i class="fa-solid fa-briefcase"></i> <%= job.job_type %></span>
            <span class="tag" style="font-size: 0.8rem; padding: 4px 10px;"><i class="fa-solid fa-calendar-days"></i> Apply by <%= new Date(job.deadline).toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
        </div>

        <h3 style="margin-bottom: 12px; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.2px;">Job Description</h3>
        <p style="color: var(--text-secondary); line-height: 1.6; white-space: pre-line; margin-bottom: 28px; font-size: 0.95rem;">
            <%= job.description %>
        </p>

        <h3 style="margin-bottom: 12px; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.2px;">Skills Required</h3>
        <div class="skills-badge-list">
            <% job.skills_required.split(',').forEach(skill => { %>
                <span class="skills-badge" style="font-size: 0.78rem; padding: 4px 10px;"><%= skill.trim() %></span>
            <% }); %>
        </div>
    </div>

    <!-- Application Form or Status Section -->
    <div>
        <% if (hasApplied) { %>
            <div class="card" style="border-color: rgba(16, 185, 129, 0.2); background: #f0fdf4;">
                <div style="text-align: center; padding: 16px 10px;">
                    <i class="fa-solid fa-circle-check" style="font-size: 2.8rem; color: var(--color-success); margin-bottom: 16px;"></i>
                    <h3 style="margin-bottom: 8px; font-weight: 800; letter-spacing: -0.2px;">Application Submitted</h3>
                    <p style="color: var(--text-secondary); font-size: 0.88rem; margin-bottom: 24px; line-height: 1.4;">You have successfully applied for this job listing. You can track its status in your dashboard.</p>
                    
                    <div style="background-color: #ffffff; padding: 14px; border-radius: 8px; border: 1px solid var(--border-color); display: inline-block; width: 100%;">
                        <span style="font-size: 0.8rem; color: var(--text-secondary); display: block; margin-bottom: 6px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Current Status</span>
                        <span class="status-badge status-<%= application.status.toLowerCase() %>" style="font-size: 0.82rem; padding: 6px 16px;">
                            <%= application.status %>
                        </span>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="card">
                <h3 style="margin-bottom: 8px; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.2px;">Apply to Position</h3>
                <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 20px; line-height: 1.4;">Submit your resume. Only PDF format is accepted, maximum size 5MB.</p>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger" style="padding: 10px 14px; margin-bottom: 16px; font-size: 0.8rem;">
                        <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
                    </div>
                <% } %>

                <form action="/apply" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="job_id" value="<%= job.id %>">
                    
                    <div class="form-group" style="margin-bottom: 24px;">
                        <label for="resume">Upload PDF Resume</label>
                        <input type="file" id="resume" name="resume" accept="application/pdf" required style="padding: 8px; border-style: dashed; border-width: 2px;">
                    </div>

                    <button type="submit" class="btn btn-primary btn-block" style="width: 100%; padding: 12px;">
                        <i class="fa-solid fa-paper-plane"></i> Submit Application
                    </button>
                </form>
            </div>
        <% } %>
    </div>
</div>

<%- include('../layouts/footer') %>
