<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'HireHub - Job & Internship Portal' %></title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Local Stylesheet -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <div class="navbar">
            <a href="/" class="logo">
                <i class="fa-solid fa-briefcase"></i> Hire<span>Hub</span>
            </a>
            
            <nav>
                <ul class="nav-links">
                    <% if (typeof user !== 'undefined' && user) { %>
                        <% if (user.role === 'applicant') { %>
                            <li><a href="/applicant/dashboard"><i class="fa-solid fa-house"></i> Jobs</a></li>
                            <li><a href="/applicant/applications"><i class="fa-solid fa-paper-plane"></i> My Applications</a></li>
                        <% } else if (user.role === 'recruiter') { %>
                            <li><a href="/recruiter/dashboard"><i class="fa-solid fa-chart-line"></i> Dashboard</a></li>
                            <li><a href="/recruiter/post-job"><i class="fa-solid fa-circle-plus"></i> Post Job</a></li>
                        <% } else if (user.role === 'admin') { %>
                            <li><a href="/admin/dashboard"><i class="fa-solid fa-user-shield"></i> Admin Panel</a></li>
                        <% } %>
                    <% } else { %>
                        <li><a href="/auth/login">Login</a></li>
                        <li><a href="/auth/register">Register</a></li>
                    <% } %>
                </ul>
            </nav>

            <% if (typeof user !== 'undefined' && user) { %>
                <div class="nav-user">
                    <span class="user-badge"><i class="fa-solid fa-user"></i> <%= user.role %>: <%= user.name %></span>
                    <a href="/auth/logout" class="btn btn-secondary btn-text" title="Logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                </div>
            <% } else { %>
                <div class="nav-user">
                    <a href="/auth/login" class="btn btn-primary">Login</a>
                </div>
            <% } %>
        </div>
    </header>
    <main class="container">
