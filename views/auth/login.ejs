<%- include('../layouts/header') %>

<div class="card form-card">
    <div style="text-align: center; margin-bottom: 24px;">
        <i class="fa-solid fa-right-to-bracket" style="font-size: 2.2rem; color: var(--color-primary); margin-bottom: 8px;"></i>
        <h2>Welcome Back</h2>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Sign in to your HireHub account</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger">
            <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
        </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">
            <i class="fa-solid fa-circle-check"></i> <%= success %>
        </div>
    <% } %>

    <form action="/auth/login" method="POST">
        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="e.g. yourname@domain.com">
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required placeholder="Enter password">
        </div>

        <button type="submit" class="btn btn-primary btn-block" style="width: 100%; margin-top: 10px; padding: 12px;">
            <i class="fa-solid fa-right-to-bracket"></i> Login
        </button>
    </form>

    <div style="text-align: center; margin-top: 20px; font-size: 0.9rem; color: var(--text-secondary);">
        Don't have an account? <a href="/auth/register" style="color: var(--color-primary); text-decoration: none; font-weight: 600;">Register here</a>
    </div>
</div>

<%- include('../layouts/footer') %>
