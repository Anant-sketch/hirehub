<%- include('layouts/header') %>

<div class="card" style="max-width: 600px; margin: 80px auto; text-align: center; border-color: rgba(239, 68, 68, 0.3);">
    <i class="fa-solid fa-triangle-exclamation" style="font-size: 3.5rem; color: #ef4444; margin-bottom: 20px;"></i>
    <h2 style="margin-bottom: 12px;"><%= typeof title !== 'undefined' ? title : 'Error Occurred' %></h2>
    <p style="color: var(--text-secondary); margin-bottom: 24px;"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred. Please try again.' %></p>
    
    <% if (typeof user !== 'undefined' && user) { %>
        <% if (user.role === 'applicant') { %>
            <a href="/applicant/dashboard" class="btn btn-primary"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
        <% } else if (user.role === 'recruiter') { %>
            <a href="/recruiter/dashboard" class="btn btn-primary"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
        <% } else if (user.role === 'admin') { %>
            <a href="/admin/dashboard" class="btn btn-primary"><i class="fa-solid fa-arrow-left"></i> Back to Panel</a>
        <% } %>
    <% } else { %>
        <a href="/auth/login" class="btn btn-primary">Go to Login</a>
    <% } %>
</div>

<%- include('layouts/footer') %>
