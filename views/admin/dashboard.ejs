<%- include('../layouts/header') %>

<div class="page-title-section">
    <div>
        <h1>System Administration Panel</h1>
        <p style="color: var(--text-secondary); margin-top: 4px;">Monitor all registered accounts, manage job listings, and perform cleanups</p>
    </div>
</div>

<!-- Grid Layout: Users Management on Left/Full, Jobs on Right/Full -->
<div style="display: grid; grid-template-columns: 1fr; gap: 32px; margin-bottom: 40px;">
    
    <!-- Users Management Card -->
    <div class="card" style="padding: 24px;">
        <h3 style="margin-bottom: 16px; font-weight: 700; display: flex; align-items: center; gap: 8px;">
            <i class="fa-solid fa-users text-emerald"></i> Registered Users (<%= users.length %>)
        </h3>
        
        <% if (users.length > 0) { %>
            <div class="table-container" style="margin-bottom: 0;">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email Address</th>
                            <th>Role</th>
                            <th>Joined Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(account => { %>
                            <tr>
                                <td style="font-weight: 700; color: #ffffff;"><%= account.name %></td>
                                <td><%= account.email %></td>
                                <td>
                                    <span class="user-badge" style="text-transform: capitalize; background: rgba(255,255,255,0.03);">
                                        <%= account.role %>
                                    </span>
                                </td>
                                <td><%= new Date(account.created_at).toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                <td>
                                    <form action="/admin/users/delete/<%= account.id %>" method="POST" onsubmit="return confirm('WARNING: Deleting this user will remove all their data, jobs, and applications! Proceed?');">
                                        <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 0.8rem;">
                                            <i class="fa-solid fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state" style="padding: 30px;">
                <p>No other registered users found in the system database.</p>
            </div>
        <% } %>
    </div>

    <!-- Jobs Management Card -->
    <div class="card" style="padding: 24px;">
        <h3 style="margin-bottom: 16px; font-weight: 700; display: flex; align-items: center; gap: 8px;">
            <i class="fa-solid fa-briefcase text-emerald"></i> Active Job Listings (<%= jobs.length %>)
        </h3>

        <% if (jobs.length > 0) { %>
            <div class="table-container" style="margin-bottom: 0;">
                <table>
                    <thead>
                        <tr>
                            <th>Job Title</th>
                            <th>Company (Recruiter)</th>
                            <th>Location</th>
                            <th>Stipend</th>
                            <th>Deadline</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% jobs.forEach(job => { %>
                            <tr>
                                <td style="font-weight: 700; color: #ffffff;"><%= job.title %></td>
                                <td style="font-weight: 600; color: var(--color-primary);"><%= job.company_name %></td>
                                <td><%= job.location %></td>
                                <td><i class="fa-solid fa-indian-rupee-sign"></i> <%= job.stipend.toLocaleString() %>/mo</td>
                                <td><%= new Date(job.deadline).toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                <td>
                                    <form action="/admin/jobs/delete/<%= job.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this job listing? All linked candidate applications will be deleted.');">
                                        <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 0.8rem;">
                                            <i class="fa-solid fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state" style="padding: 30px;">
                <p>No active job listings found in the database.</p>
            </div>
        <% } %>
    </div>
</div>

<%- include('../layouts/footer') %>
